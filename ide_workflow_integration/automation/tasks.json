{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "AI Code Review",
      "type": "shell",
      "command": "bash",
      "args": [
        "${workspaceFolder}/automation/ai_review_hook.sh"
      ],
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "problemMatcher": []
    },
    {
      "label": "Auto Document Generation",
      "type": "shell",
      "command": "python3",
      "args": [
        "${workspaceFolder}/automation/auto_doc_generate.py",
        "${workspaceFolder}"
      ],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}
